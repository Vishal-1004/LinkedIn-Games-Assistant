{
  "manifest_version": 3,
  "name": "LinkedIn Sudoku & Queens Assistant",
  "version": "2.0",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.linkedin.com/games/mini-sudoku/*",
        "*://www.linkedin.com/games/queens/*",
        "*://www.linkedin.com/games/tango/*"
      ],
      "js": ["sudoku_solver.js", "queens_solver.js", "content.js"]
    }
  ],
  "permissions": ["activeTab"]
}
